DATABASE_URL=postgresql+psycopg2://scholarpilot:scholarpilot@db:5432/scholarpilot
SECRET_KEY=please-change-me
UPLOAD_DIR=/app/uploads

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_VERSION=1
EMBEDDING_BACKEND=auto
# Hash embeddings are disabled unless this is explicitly true.
ALLOW_EMBEDDING_FALLBACK=false

MAX_UPLOAD_SIZE_MB=20
RETRIEVAL_MODE=hybrid
RETRIEVAL_CANDIDATE_K=20
RETRIEVAL_MIN_RELEVANCE=0.25
HYBRID_RRF_K=60
HYBRID_VECTOR_MODE=hnsw
HNSW_M=16
HNSW_EF_CONSTRUCTION=64
HNSW_EF_SEARCH=40

# Mock mode is explicit and is labelled as mock in API/runtime status.
LLM_PROVIDER=mock

# To call a real OpenAI-compatible chat model, uncomment and fill these values.
# LLM_PROVIDER=openai-compatible
# LLM_API_BASE=https://api.openai.com/v1
# LLM_API_KEY=your-api-key
# LLM_MODEL=gpt-4o-mini
# LLM_TIMEOUT_SECONDS=30
