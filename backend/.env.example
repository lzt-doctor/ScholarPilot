DATABASE_URL=postgresql+psycopg2://scholarpilot:scholarpilot@db:5432/scholarpilot
SECRET_KEY=please-change-me
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
# Optional future alternatives:
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_MODEL=intfloat/multilingual-e5-base
# If you switch to a model with a different vector size, also update
# EMBEDDING_DIMENSION and re-embed/recreate existing document_chunks.
EMBEDDING_BACKEND=auto
LLM_PROVIDER=mock
